{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "shell:allow-open",
    "autostart:default",
    "dialog:default",
    "dialog:allow-open"
  ]
}
