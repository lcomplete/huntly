{
  "compilerOptions": {
    "strict": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "es6",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "noEmitOnError": true,
    "jsx": "react-jsx",
    "typeRoots": ["node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "entrypoints", "wxt.config.ts"],
  "exclude": ["src/__tests__"]
}
